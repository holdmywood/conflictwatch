generator client {
  provider = "prisma-client-js"
  // Local dev binary is added automatically; the rhel target is required for
  // Vercel's serverless runtime and Railway's container.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conflict {
  id          String    @id
  name        String
  region      String
  status      String    @default("active")
  threatLevel Int
  lat         Float
  lng         Float
  updatedAt   DateTime  @updatedAt
  events      Event[]
  situations  Situation[]
  // §5: present-state synthesis
  situationStatus      String @default("")
  currentSituationLine String @default("")
}

// §3: multi-day developing-story clustering
// Groups related events into a story thread over a 7-day window.
// Events match a situation when they share conflictId + region and overlapping actors/CAMEO root.
model Situation {
  id          String   @id @default(cuid())
  conflictId  String
  conflict    Conflict @relation(fields: [conflictId], references: [id])
  title       String
  status      String   @default("emerging") // emerging|escalating|ongoing|de-escalating|resolved
  location    String
  actors      String[]
  cameoRoots  String[]
  eventIds    String[]
  firstSeenAt DateTime
  lastSeenAt  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([conflictId])
  @@index([status])
  @@index([lastSeenAt])
}

model Event {
  id          String        @id @default(cuid())
  clusterId   String        @unique
  title       String
  summary     String        @default("")
  actor1      String?
  actor2      String?
  eventType   String
  lat         Float
  lng         Float
  region      String
  confidence  String        @default("low")
  publishedAt DateTime
  ingestedAt  DateTime      @default(now())
  conflictId  String?
  conflict    Conflict?     @relation(fields: [conflictId], references: [id])
  sources     EventSource[]
  // §2: AI classification fields
  severity           Int      @default(1)
  // Fatality count (UCDP `best` estimate); 0 for sources without fatality data
  // (GDELT). Drives lethality-weighted threat intensity.
  fatalities         Int      @default(0)
  significance       String   @default("")
  category           String   @default("")
  stabilityImpact    String   @default("")
  sourceTier         String   @default("")
  locationConfidence String   @default("medium")
  classified         Boolean  @default(false)
  summarized         Boolean  @default(false)
  // §A5: latency tracking
  firstReportAt      DateTime?
  signalAt           DateTime?
  // §12: surprise/coverage-gap scoring
  surpriseScore      Float     @default(0)

  @@index([conflictId])
  @@index([classified])
  @@index([publishedAt])
  @@index([conflictId, publishedAt])
  @@index([surpriseScore])
}

model EventSource {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  url         String
  publishedAt DateTime
  event       Event    @relation(fields: [eventId], references: [id])

  @@unique([eventId, url])
  @@index([eventId])
}

model Assessment {
  id           String   @id @default(cuid())
  region       String
  kind         String
  body         String
  confidence   String
  usedEventIds String[]
  createdAt    DateTime @default(now())
}

// §6: escalation / early-warning signals
// Supersedes Assessment(kind='prediction') for forward-looking signals.
model EscalationSignal {
  id              String    @id @default(cuid())
  scope           String    // 'country' | 'actor'
  targetId        String    // conflictId or actor name
  // LLM-assessed fields
  escalationRisk  String    @default("none") // 'none'|'watch'|'elevated'|'high'
  trajectory      String    @default("stable")
  drivers         String[]
  actorsOfConcern String[]
  horizon         String    @default("")
  rationale       String    @default("")
  confidence      String    @default("low")
  usedEventIds    String[]
  triggeringFeatures Json   @default("{}")
  // §A1: calibrated probability (set by model, not LLM)
  pEscalation     Float?    // 0–1, P(national-level escalation within horizonDays)
  ciLow           Float?
  ciHigh          Float?
  horizonDays     Int?
  modelVersion    String    @default("v0")
  // Outcome recording (filled on resolution for calibration)
  resolvedOutcome Boolean?
  resolvedAt      DateTime?
  // §A8: link to point-in-time episode
  episodeId       String?
  episode         EpisodeStore?      @relation(fields: [episodeId], references: [id])
  calibrations    CalibrationRecord[]
  computedAt      DateTime  @default(now())
  supersededAt    DateTime? // set when a newer signal for same targetId replaces this

  @@index([targetId])
  @@index([computedAt])
  @@index([escalationRisk])
}

// §A1 / §A2 / §A8: point-in-time episode store
// Stores ONLY features knowable at signal time. Outcomes filled retrospectively
// using as-reported (never later-revised) data. Backs calibration + analogue engine.
model EpisodeStore {
  id               String    @id @default(cuid())
  conflictId       String
  // Snapshot metadata
  snapshotAt       DateTime  // exact moment these features were recorded
  // Numeric trend features (point-in-time)
  eventTempo       Float     @default(0)  // events/day in trailing window
  severitySlope    Float     @default(0)  // Δavg-severity over window (+ = rising)
  spreadLocations  Int       @default(0)  // distinct location count in window
  sourceBreadth    Int       @default(0)  // independent tier1/tier2 source count
  actorCount       Int       @default(0)  // distinct named actors in window
  // Categorical tags for similarity filtering
  geographyClass   String    @default("") // 'chokepoint-adj'|'landlocked'|'coastal'|'island'
  actorTypes       String[]              // 'state'|'insurgent'|'militia'|'criminal'
  chokepoints      String[]              // e.g. ['hormuz','bab-el-mandeb']
  commodityTags    String[]              // e.g. ['oil','grain','shipping']
  // As-reported outcomes (filled retrospectively — never hindsight-revised)
  escalatedToNational   Boolean?
  escalationHorizonDays Int?
  assetMovesJson        Json?   // {instrument: {d5: float, d10: float, d20: float}}
  // Traceability
  usedEventIds     String[]
  modelVersion     String    @default("v0")
  // Relations
  signals          EscalationSignal[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([conflictId])
  @@index([snapshotAt])
}

// §A1: per-signal calibration log
// Every probabilistic call is recorded here so a Brier score and reliability
// curve can be computed as outcomes accumulate — retroactive logging is impossible.
model CalibrationRecord {
  id            String    @id @default(cuid())
  signalId      String
  pEscalation   Float
  ciLow         Float
  ciHigh        Float
  horizonDays   Int
  modelVersion  String
  // Outcome (filled when resolvedAt reaches horizonDays past computedAt)
  resolvedAt    DateTime?
  actualOutcome Boolean?  // true = escalated to national level
  brierScore    Float?    // (p − outcome)² — lower is better
  computedAt    DateTime  @default(now())

  signal EscalationSignal @relation(fields: [signalId], references: [id])

  @@index([signalId])
  @@index([computedAt])
  @@index([resolvedAt])
}

// §B: source-credibility framework
// Per-domain editorial credibility, updated continuously.
// Tier assignment reflects standards (with corrections policy, bylines, etc.),
// NOT nationality. Credible regional papers of record can reach tier1.
model DomainReliability {
  domain             String   @id
  tier               String   // 'tier1'|'tier2'|'specialist'|'blocked'|'review'
  reliabilityScore   Float    @default(1.0) // 1.0 = full trust; decays on corrections/contradictions
  correctionsCount   Int      @default(0)
  contradictionCount Int      @default(0)
  totalUsageCount    Int      @default(0)
  reviewNotes        String   @default("")
  lastUpdatedAt      DateTime @default(now())

  @@index([tier])
}

model Heartbeat {
  id              Int      @id @default(1)
  lastIngestedAt  DateTime
  sourcesOk       Int
  sourcesFailed   Int
  // §A9: cost/volume telemetry
  classifyCalls   Int      @default(0)
  escalationCalls Int      @default(0)
  summaryCalls    Int      @default(0)
}

model User {
  id        String          @id @default(cuid())
  email     String          @unique
  password  String
  tier      String          @default("free")
  createdAt DateTime        @default(now())
  watchlist WatchlistItem[]
  watchlistRules WatchlistRule[]
}

model WatchlistItem {
  id         String @id @default(cuid())
  userId     String
  conflictId String
  user       User   @relation(fields: [userId], references: [id])

  @@unique([userId, conflictId])
}

// §A9: exposure graph — links geographic zones to market instruments
// Versioned, curated table. Seed from packages/db/seed-exposures.ts.
model ExposureLink {
  id              String   @id @default(cuid())
  zone            String   // slug: 'hormuz'|'suez'|'ukraine'|'russia'|...
  zoneLabel       String   // display: 'Strait of Hormuz'
  zoneType        String   // 'chokepoint'|'commodity_region'|'shipping_lane'
  instrument      String   // slug: 'brent'|'ttf'|'wheat'|'container-freight'|...
  instrumentLabel String   // display: 'Brent Crude'
  assetClass      String   // 'energy'|'agriculture'|'shipping'|'metals'|'fx'|'bonds'
  linkType        String   // 'transit'|'production'|'export'|'substitute'
  weight          Float    // 0.0–1.0 directness (1.0 = sole transit/production route)
  notes           String   @default("")
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  // Editorial provenance — exposure linkages are curated judgments, never
  // fabricated. Every row says where it came from and whether a human
  // confirmed it. Unreviewed rows must be visually flagged downstream.
  provenance      String   @default("") // citation/justification for the linkage + weight
  addedBy         String   @default("seed") // 'seed' | analyst identifier
  reviewStatus    String   @default("unreviewed") // 'unreviewed' | 'approved'
  reviewedAt      DateTime?

  @@index([zone])
  @@index([instrument])
  @@index([reviewStatus])
  @@unique([zone, instrument])
}

// §A6: threshold-based watchlist rules
// Defines what to watch and at what threshold. A rule fires when its condition
// is met and has not already fired within dedupWindowHours.
model WatchlistRule {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  name             String    // human label e.g. "Oil chokepoints > 25%"
  // Trigger condition (all fields are AND-ed)
  zoneFilter       String[]  // ExposureLink zones to match; empty = any zone
  minPEscalation   Float?    // minimum pEscalation (0–1) to fire
  minSurpriseScore Float?    // minimum surpriseScore on events
  minThreatLevel   Int?      // minimum conflict threatLevel
  // Delivery
  webhookUrl       String?   // HTTPS endpoint for webhook delivery
  slackWebhookUrl  String?   // Slack incoming webhook URL
  // Deduplication
  dedupWindowHours Int       @default(24) // don't re-fire for same conflict within N hours
  enabled          Boolean   @default(true)
  createdAt        DateTime  @default(now())
  alerts           Alert[]

  @@index([userId])
}

// §A6: fired alert records
model Alert {
  id            String       @id @default(cuid())
  ruleId        String
  rule          WatchlistRule @relation(fields: [ruleId], references: [id])
  conflictId    String
  // Snapshot of what triggered the alert
  pEscalation   Float?
  surpriseScore Float?
  threatLevel   Int?
  payload       Json         // full provenance payload delivered to webhook/Slack
  deliveredAt   DateTime?    // null = pending/failed
  deliveryError String?      // last error if delivery failed
  createdAt     DateTime     @default(now())

  @@index([ruleId])
  @@index([conflictId])
  @@index([createdAt])
}

// Clusters that passed the trust gate but exceeded the per-cycle enrichment
// cap. Deferred here (oldest first) instead of being lost when the 15-minute
// GDELT file rotates; drained at the start of each ingestion cycle.
model PendingCluster {
  id          String   @id @default(cuid())
  clusterId   String   @unique
  payload     Json     // serialized NormalizedEvent[] for the cluster
  attempts    Int      @default(0)
  firstSeenAt DateTime @default(now())

  @@index([firstSeenAt])
}
