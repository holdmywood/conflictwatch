DATABASE_URL="postgresql://conflictwatch:conflictwatch@localhost:5432/conflictwatch"
ANTHROPIC_API_KEY=""

# Web: API key for /api/v1/export (Bearer or x-api-key). Endpoint is disabled when unset.
EXPORT_API_KEY=""

# Worker: ops webhook fired when ingestion heartbeat goes stale (1h alert cooldown).
OPS_ALERT_WEBHOOK_URL=""
# Worker: staleness threshold in minutes before the ops alert fires (default 30).
OPS_STALENESS_THRESHOLD_MIN="30"

# Backfill: per-run event cap for scripts/backfill-reclassify.ts (default 50).
BACKFILL_CLASSIFY_CAP="50"
